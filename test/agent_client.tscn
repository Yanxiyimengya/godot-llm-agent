[sub_resource type="GDScript" id="GDScript_bhunq"]
script/source = "extends Node

@export_multiline()
var tishichi : String = \"\";

@onready var agent_client: AgentClient = $\"..\";
var resp : AgentConversationMessages;
@onready var label: Label = $\"../ScrollContainer/Label\"

var can_use := false;

func _ready() -> void:
	await agent_client.open();
	can_use = true;

@onready var code_edit: CodeEdit = $\"../CodeEdit\"

func _on_button_pressed() -> void:
	if (!can_use) : return;
	var msg : AgentMessage = AgentMessage.new();
	msg.content = code_edit.text;
	agent_client.context.histroy_messages.append(msg.duplicate(true));
	call_deferred(\"messagea_round\");

func messagea_round() -> void :
	var s : AgentConversationMessages = agent_client.request_message();
	s.finished.connect(
		func() : 
			agent_client.context.histroy_messages.push_back(s.messages[0]);
			if (s.messages[0].tool_calls.is_empty()) : 
				return;
			var result : Dictionary[int, AgentMessageToolCall] = \\
					await agent_client.tool_call(s.messages[0]);
			if (result.is_empty()) : 
				return;
			
			for r in result : 
				agent_client.context.get_context_messages().push_back(result[r]);
			call_deferred(\"messagea_round\");
	, Object.ConnectFlags.CONNECT_ONE_SHOT);
	s.updated.connect(
		func() : 
			if (s.messages.size() > 0) : 
				label.text = \"\";
				for i in s.messages.size():
					label.text += s.messages[i].reasoning_content;
					label.text += s.messages[i].content;
					for tc : AgentToolCall in s.messages[i].tool_calls.values():
						label.text += tc.id;
						label.text += tc.name;
						label.text += tc.arguments;
			else : 
				
				label.text = s.messages[0].reasoning_content;
				label.text += s.messages[0].content;
				for tc : AgentToolCall in s.messages[0].tool_calls.values():
					label.text += tc.id;
					label.text += tc.name;
					label.text += tc.arguments;
	);
"


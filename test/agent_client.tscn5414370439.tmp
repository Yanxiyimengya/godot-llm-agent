[sub_resource type="GDScript" id="GDScript_bhunq"]
script/source = "extends Node

@onready var agent_client: AgentClient = $\"..\";
var resp : Array[AgentMessageAssistant];
@onready var label: Label = $\"../Label\"

func _ready() -> void:
	agent_client.open();
	var msg : AgentMessage = AgentMessage.new();
	msg.content = \"你是谁\";
	agent_client.context.histroy_messages.append(msg.duplicate(true));
	
	msg.content = \"我是 pig god,我想和你PVP!\";
	msg.role = AgentMessage.Role.ASSISTANT;
	agent_client.context.histroy_messages.append(msg.duplicate(true));
	
	msg.content = \"调用PVP工具\";
	msg.role = AgentMessage.Role.USER;
	agent_client.context.histroy_messages.append(msg.duplicate(true));
	
	var pvp_tool : AgentTool = preload(\"uid://h1mmjrmnyq3v\").new();
	agent_client.context.tool_list = {
		\"PVP_TOOL\" : pvp_tool
	};
	resp = agent_client.request_message();


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	for i in resp : 
		label.text = i.reasoning_content;
		label.text += i.content;
		for sss : AgentToolCall in i.tool_calls.values() : 
			label.text += sss.id;
			label.text += sss.name;
			label.text += sss.arguments;
	
"

